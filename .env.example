# Copy to .env and fill in real values. .env is gitignored — never commit it.
# Sandbox OAuth credentials for the Doc Detective token-endpoint test
# (docs/tutorial/access-api-keys.mdx). Get them from the Prove Developer
# Portal, Credentials tab of a Sandbox project.
PROVE_CLIENT_ID=your-sandbox-client-id
PROVE_CLIENT_SECRET=your-sandbox-client-secret
